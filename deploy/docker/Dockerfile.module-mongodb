ARG VERSION=dev

FROM golang:1.25-alpine AS builder

WORKDIR /src

COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ .

RUN go build -ldflags="-s -w" -o /module-mongodb ./cmd/module-mongodb

FROM alpine:3.20

RUN apk add --no-cache ca-certificates && \
    adduser -D -h /home/bacon bacon

COPY --from=builder /module-mongodb /module-mongodb

USER bacon

EXPOSE 50051

ENTRYPOINT ["/module-mongodb"]
